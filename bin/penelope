#!/usr/bin/env bash
#
# penelope — start Penelope with a single command (like `claude`).
#
# Brings up (if needed) Ollama, the backend (FastAPI/uvicorn :8000) and the
# frontend (SvelteKit/Vite :5173), waits for the frontend and opens the browser.
# Ctrl+C stops everything.
#
# Install: linked at ~/.local/bin/penelope. Edit this file in the repo.
# First time on a fresh machine? Run `bin/setup` once.

set -euo pipefail

# --- Resolve the project root, following the ~/.local/bin symlink -------------
SOURCE="${BASH_SOURCE[0]}"
while [ -h "$SOURCE" ]; do
	DIR="$(cd -P "$(dirname "$SOURCE")" >/dev/null 2>&1 && pwd)"
	SOURCE="$(readlink "$SOURCE")"
	[[ $SOURCE != /* ]] && SOURCE="$DIR/$SOURCE"
done
BIN_DIR="$(cd -P "$(dirname "$SOURCE")" >/dev/null 2>&1 && pwd)"
ROOT="$(cd "$BIN_DIR/.." >/dev/null 2>&1 && pwd)"

BACKEND_PORT=8000
FRONTEND_PORT=5173
OLLAMA_URL="http://127.0.0.1:11434"
APP_URL="http://localhost:${FRONTEND_PORT}"

PIDS=()
OLLAMA_PID=""

cleanup() {
	echo ""
	echo "penelope: shutting down…"
	for pid in "${PIDS[@]:-}"; do
		[ -n "$pid" ] && kill "$pid" 2>/dev/null || true
	done
	# Only stop Ollama if WE started it.
	[ -n "$OLLAMA_PID" ] && kill "$OLLAMA_PID" 2>/dev/null || true
	exit 0
}
trap cleanup INT TERM

wait_for() { # $1 = url, $2 = name, $3 = attempts
	local i=0
	until curl -fsS "$1" >/dev/null 2>&1; do
		i=$((i + 1))
		if [ "$i" -ge "${3:-60}" ]; then
			echo "penelope: $2 did not respond in time." >&2
			return 1
		fi
		sleep 0.5
	done
}

echo "penelope: project root = $ROOT"

# --- 1) Ollama ----------------------------------------------------------------
if curl -fsS "${OLLAMA_URL}/api/tags" >/dev/null 2>&1; then
	echo "penelope: Ollama is already running."
elif command -v ollama >/dev/null 2>&1; then
	echo "penelope: starting Ollama…"
	ollama serve >/dev/null 2>&1 &
	OLLAMA_PID=$!
	wait_for "${OLLAMA_URL}/api/tags" "Ollama" 60 || true
else
	echo "penelope: WARNING — 'ollama' not found. Run 'bin/setup' or install it from https://ollama.com." >&2
fi

# --- 1b) Make sure the required models are present ----------------------------
if command -v ollama >/dev/null 2>&1 && curl -fsS "${OLLAMA_URL}/api/tags" >/dev/null 2>&1; then
	ensure_model() { # $1 = tag to pull, $2 = grep pattern for an acceptable match
		if ! ollama list 2>/dev/null | grep -qi "$2"; then
			echo "penelope: model missing, pulling $1 … (first run only)"
			ollama pull "$1" || echo "penelope: failed to pull $1 (try 'bin/setup')." >&2
		fi
	}
	ensure_model "qwen3-vl:8b" "qwen3-vl"
	ensure_model "embeddinggemma" "embeddinggemma"
fi

# --- 2) Backend (FastAPI) -----------------------------------------------------
echo "penelope: starting the backend (:${BACKEND_PORT})…"
(
	cd "$ROOT/backend"
	exec uv run uvicorn main:app --host 127.0.0.1 --port "$BACKEND_PORT"
) &
PIDS+=($!)

# --- 3) Frontend (Vite) -------------------------------------------------------
if [ ! -d "$ROOT/frontend/node_modules" ]; then
	echo "penelope: installing frontend dependencies (first run)…"
	(cd "$ROOT/frontend" && npm install)
fi
echo "penelope: starting the frontend (:${FRONTEND_PORT})…"
(
	cd "$ROOT/frontend"
	exec npm run dev -- --port "$FRONTEND_PORT" --strictPort
) &
PIDS+=($!)

# --- 4) Wait and open the browser --------------------------------------------
if wait_for "$APP_URL" "frontend" 80; then
	echo "penelope: ready -> $APP_URL"
	if command -v open >/dev/null 2>&1; then
		open "$APP_URL" || true
	fi
else
	echo "penelope: open $APP_URL manually" >&2
fi

echo "penelope: running. Press Ctrl+C to stop everything."
wait
